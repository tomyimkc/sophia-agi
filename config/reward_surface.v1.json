{
  "schema": "sophia.reward_surface.v1",
  "version": 1,
  "boundary": "Declares the protected reward/verification surface for SSIL gate G2 (reward-isolation tripwire). A self-modification candidate must not WRITE the no-write surface (tampering) nor READ the blind surface (wireheading / hidden-eval leakage). Editing this file to shrink the surface is itself a reward-tampering action (constitution: no_reward_tampering) and is out of scope for any self-edit.",
  "noWriteGlobs": [
    "agent/continual_plasticity.py",
    "agent/verifier_synthesis.py",
    "agent/corrigibility_gate.py",
    "agent/reflexive_self_gate.py",
    "agent/conscience_enforcement.py",
    "constitution/*",
    "moral_corpus/*",
    "config/reward_surface.v1.json",
    "eval/conscience/*",
    "eval/**/*frozen*",
    "**/*reward*",
    "**/*threshold*",
    "**/*hidden*eval*",
    "**/hidden-evals/**",
    ".github/workflows/*",
    "tools/run_*gate*.py",
    "provenance_bench/rl_reward.py"
  ],
  "noReadGlobs": [
    "**/hidden-evals/**",
    "**/*hidden*eval*",
    "**/*.reward_scalar",
    "**/reward_channel/**",
    "private/hidden-evals/**"
  ],
  "tamperPatterns": [
    "weaken the verifier",
    "lower the threshold",
    "bypass ci",
    "edit the reward",
    "reward tampering",
    "train on hidden eval",
    "reveal hidden pack",
    "leak hidden benchmark",
    "disable the gate",
    "skip verification"
  ]
}
