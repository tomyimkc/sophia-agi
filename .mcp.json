{
  "mcpServers": {
    "sophia-agi": {
      "command": "python3",
      "args": ["sophia_mcp/server.py"],
      "env": {
        "PYTHONPATH": "."
      }
    },
    "runpod": {
      "command": "npx",
      "args": ["-y", "@runpod/mcp-server@latest"],
      "env": {
        "RUNPOD_API_KEY": "${RUNPOD_API_KEY}"
      }
    }
  }
}
