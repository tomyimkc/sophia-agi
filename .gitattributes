training/mlx_adapters/**/*.safetensors filter=lfs diff=lfs merge=lfs -text

# --- git-crypt: private files encrypted in this PUBLIC repo ---
# Files matched below are encrypted before they are pushed. The public sees
# only ciphertext; locally (after `git-crypt unlock`) they are normal files.
# Convention: keep private things either under secret/ or with a .secret.* name.
secret/** filter=git-crypt diff=git-crypt
*.secret.md filter=git-crypt diff=git-crypt
*.secret.json filter=git-crypt diff=git-crypt
*.private.md filter=git-crypt diff=git-crypt
# NOTE: never add a rule that would encrypt .gitattributes itself.

# --- Specific existing paths the owner chose to make private ---
# Internal design docs (methodology / how-this-is-built):
docs/superpowers/** filter=git-crypt diff=git-crypt
# Agent operating + governance instructions:
AGENTS.md filter=git-crypt diff=git-crypt
CONTRACT.md filter=git-crypt diff=git-crypt
# Local agent/tooling skill definitions:
.claude/skills/** filter=git-crypt diff=git-crypt
# Exception: process/operational skills carry NO IP and must stay readable even when the repo
# is locked (no git-crypt key) so a fresh Claude-Code-on-the-web session can use them without
# unlocking. The encrypted IP skills above (sophia-agi, runpod-mcp) are unaffected (last match wins).
.claude/skills/git-discipline/** !filter !diff
.claude/skills/ci-artifact-drift/** !filter !diff
.claude/skills/session-handover/** !filter !diff
.claude/skills/skill-author/** !filter !diff
.claude/skills/spark-cluster-ops/** !filter !diff
.claude/skills/rlvr-harness-traps/** !filter !diff
.grok/** filter=git-crypt diff=git-crypt
agi-proof/benchmark-results/**/*.tar.gz filter=lfs diff=lfs merge=lfs -text
