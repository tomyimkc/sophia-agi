+    --bench-a)       RUN_A=1 ;;
+    --bench-b)       RUN_B=1 ;;
+    --bench-virtues) RUN_VIRTUES=1 ;;
+    --all)           RUN_A=1; RUN_B=1 ;;
+    --execute)       DRY_RUN=0 ;;
