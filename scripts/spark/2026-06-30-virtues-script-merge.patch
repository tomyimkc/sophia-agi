+  step "V3 — Score 3 arms vs a REAL no-gate/no-auditor baseline (paired Δ + bootstrap CI)"
+  run "${PY}" tools/run_sophrosyne_eval.py --model "${VIRTUE_SUBJECT}" --seeds "${VIRTUE_SEEDS}" --write
