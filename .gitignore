# ──────────────────────────────────────────────────────────────────────────
# OPEN-CORE: keep the FUTURE training recipe + algorithm tuning private.
#
# Honest scope: the already-committed v1–v3 recipe/adapters above are PUBLIC and
# cannot be un-published (git history + forks already have them). These rules
# only stop *new* (v4+) recipe artifacts from leaking into the public repo. The
# primary protection is a separate private repo — see docs/PRIVATE-REPO-SETUP.md.
# ──────────────────────────────────────────────────────────────────────────

# Local-only working area for vNext recipe/algorithm (never committed here).
private/

# Explicit-private convention: any file you name *.private.* stays out.
**/*.private.*
.env.private

# New training-run hyperparameter dumps (v2/v3 are whitelisted above as proof).
training/**/training_run_v[4-9]*.json
training/**/*.recipe.json

# Real (non-sample) experiment/recipe configs — commit only sanitized *.sample.json.
configs/*.json
!configs/*.sample.json

# Per-session local run logs + editor backups on the shared Spark checkout
# (regenerable; committed deliverables live under agi-proof/benchmark-results/).
training/lora/*.log
training/lora/*.log.*
tools/*.bak
spark-logs/
rlvr-seed*.log
training/rlvr/

# Ephemeral cross-session coordination scratch (explicitly not-for-commit)
/SESSION-COORDINATION.md
/bridge-info.txt

# Personal setup / secrets (if secret/ has tracked files, also run:
#   git rm -r --cached secret/   then commit, to stop tracking them).
secret/**
!secret/.gitkeep

