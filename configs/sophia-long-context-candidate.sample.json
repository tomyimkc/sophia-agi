  "promotionThresholds": {
    "minimumSeeds": 3,
    "minimumAcceptedEvidenceCardRate": 0.95,
    "maxUnsupportedClaimRate": 0.02,
    "maxFalsePositiveRegression": 0.02,
    "maxWrongToolRate": 0.05,
