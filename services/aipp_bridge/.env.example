# Sophia ↔ AIpp bridge configuration.
# The bridge FAILS CLOSED: with no token set, every authed endpoint returns 503.

# Shared secret the AIpp app sends as `Authorization: Bearer <token>`.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SOPHIA_AIPP_TOKEN=

# Inherited from the RAG service (see ../../.env.example for the full set):
# SOPHIA_RAG_BACKEND=gemini        # auto | gemini | vertex | claude | local
# SOPHIA_RAG_INDEX_DIR=rag/index
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
