    {"name": "wiki-validate", "cmd": ["python3", "tools/wiki_validate.py"], "verification": true},
    {"name": "provenance-lint", "cmd": ["python3", "tools/lint_wiki_provenance.py"], "verification": true},
    {"name": "memory-eval", "cmd": ["python3", "tools/run_memory_eval.py", "--out", "/tmp/long-horizon-memory.json"], "verification": true}
  ]
}
