{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sophia Third-Party Hidden Pack Workflow",
  "type": "object",
  "required": [
    "kind",
    "manifestVersion",
    "status",
    "candidateOnly",
    "canClaimAGI",
    "claimBoundary",
    "failureLedgerRefs",
    "roles",
    "stages",
    "artifactManifestTemplate"
  ],
  "properties": {
    "kind": { "const": "third-party-hidden-pack-workflow" },
    "manifestVersion": { "type": "string" },
    "status": { "const": "scaffolding_only_not_run" },
    "candidateOnly": { "const": true },
    "canClaimAGI": { "const": false },
    "claimBoundary": { "type": "string" },
    "failureLedgerRefs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "roles": {
      "type": "object",
      "required": ["reviewer", "operator", "auditor"],
      "properties": {
        "reviewer": { "type": "string" },
        "operator": { "type": "string" },
        "auditor": { "type": "string" }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "owner", "requiredArtifacts", "publicBeforeRun"],
        "properties": {
          "id": { "type": "string" },
          "owner": {
            "enum": [
              "reviewer",
              "operator",
              "auditor"
            ]
          },
          "requiredArtifacts": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "publicBeforeRun": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "artifactManifestTemplate": {
      "type": "object",
      "required": [
        "packId",
        "runId",
        "visibility",
        "hiddenStatus",
        "schemaValidation",
        "promptLeakageAudit",
        "resultArtifact",
        "failureLedgerUpdate",
        "canClaimAGI"
      ],
      "properties": {
        "packId": { "type": ["string", "null"] },
        "runId": { "type": ["string", "null"] },
        "visibility": { "type": "string" },
        "hiddenStatus": { "type": "string" },
        "schemaValidation": { "type": ["string", "null"] },
        "promptLeakageAudit": { "type": ["string", "null"] },
        "resultArtifact": { "type": ["string", "null"] },
        "failureLedgerUpdate": { "type": ["string", "null"] },
        "canClaimAGI": { "const": false }
      }
    }
  }
}
