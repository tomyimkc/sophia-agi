{
  "$schema": "./benchmark-run.schema.json",
  "kind": "external-benchmark-workflow-manifest",
  "manifestVersion": "0.1.0",
  "status": "scaffolding_only_not_run",
  "candidateOnly": true,
  "canClaimAGI": false,
  "claimBoundary": "Workflow declarations only. No ARC-AGI, GAIA, SWE-bench, METR-style, or third-party hidden-pack benchmark result is declared by this manifest.",
