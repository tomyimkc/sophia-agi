      "prompt_or_task_visibility_policy",
      "per_task_logs",
      "raw_outputs",
      "scoring_script_or_official_submission",
      "aggregate_report",
      "artifact_checksums",
      "failure_ledger_update"
    ],
    "checksumAlgorithm": "sha256",
    "resultPromotionRules": {
      "minimumSeedsForHeadline": 3,
      "requireFailureLedgerUpdate": true,
      "requireCanClaimAGIFalse": true
    }
  },
