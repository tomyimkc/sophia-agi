[runpod] remote training script:

set -Eeuo pipefail
export DEBIAN_FRONTEND=noninteractive
export HF_HOME=/workspace/.cache/huggingface
export HF_HUB_CACHE=/workspace/.cache/huggingface/hub
export PIP_CACHE_DIR=/workspace/.cache/pip
export SOPHIA_MODEL=Qwen/Qwen2.5-7B-Instruct
export SOPHIA_EPOCHS=2
export SOPHIA_SEED=0
mkdir -p /workspace/sophia-runpod /workspace/.cache/huggingface/hub /workspace/.cache/pip
cd /workspace/sophia-runpod
if [ git = "git" ] && [ ! -d sophia-agi/.git ]; then
  git clone --depth 1 --branch claude/sophia-7b-train-verify https://github.com/tomyimkc/sophia-agi.git sophia-agi
fi
cd sophia-agi
(git rev-parse HEAD || true) | tee /workspace/sophia-runpod/repo-head.txt
nvidia-smi || true
python -m pip install --upgrade pip setuptools wheel
python -m pip install -r requirements-lora.txt   # torch pinned <2.9 -> ABI stable

# 1) use the COMMITTED sealed pack (decontaminated; holdout sealed off-pod)
python tools/build_local_sophia_dataset.py --check

# 2) REAL training — the research-backed gate-disciplined recipe. Adapter is tarred
#    immediately after so it always comes back even if eval/promote later fail.
python tools/train_lora.py   --model "$SOPHIA_MODEL" --4bit --rslora --neftune-alpha 5 --weight-decay 0.05   --scaffold --guard --eval-every 25 --patience 4 --train training/local_sophia_7b/mlx/train.jsonl   --epochs "$SOPHIA_EPOCHS" --seed "$SOPHIA_SEED"   --output /workspace/sophia-runpod/sophia-agi/training/lora/checkpoints/sophia-cuda-v1
if [ -d /workspace/sophia-runpod/sophia-agi/training/lora/checkpoints/sophia-cuda-v1 ]; then
  tar -czf /workspace/sophia-runpod/sophia-cuda-v1.tar.gz -C $(dirname /workspace/sophia-runpod/sophia-agi/training/lora/checkpoints/sophia-cuda-v1) $(basename /workspace/sophia-runpod/sophia-agi/training/lora/checkpoints/sophia-cuda-v1)
  cp /workspace/sophia-runpod/sophia-agi/training/lora/checkpoints/sophia-cuda-v1/sophia_lora_config.json /workspace/sophia-runpod/sophia_lora_config.json || true
fi

# 3) eval ladder: base · base+gate · adapter · adapter+gate (writes eval_ladder_adapter.json)
python tools/eval_ladder.py --backend hf --model "$SOPHIA_MODEL" --adapter /workspace/sophia-runpod/sophia-agi/training/lora/checkpoints/sophia-cuda-v1   || echo "[train] eval_ladder failed (non-fatal); adapter still returned"
cp training/local_sophia_v2/eval_ladder_adapter.json /workspace/sophia-runpod/eval_ladder_adapter.json 2>/dev/null || true

# 4) W2 promotion gate (protected-floor proof; reads the eval ladder + adapter seed)
python tools/promote_adapter.py   --adapter-config /workspace/sophia-runpod/sophia-agi/training/lora/checkpoints/sophia-cuda-v1/sophia_lora_config.json   --out /workspace/sophia-runpod/promotion.public-report.json   || echo "[train] promote_adapter failed (non-fatal)"

echo "===== sophia_lora_config.json ====="; cat /workspace/sophia-runpod/sophia_lora_config.json 2>/dev/null || true
echo "===== eval_ladder_adapter.json ====="; cat /workspace/sophia-runpod/eval_ladder_adapter.json 2>/dev/null || true
echo "===== promotion.public-report.json ====="; cat /workspace/sophia-runpod/promotion.public-report.json 2>/dev/null || true
echo "Sophia real training run complete."

