    "fallbackSeat": {
      "seatId": "general_economist_seat",
      "displayName": "General economist",
      "sourceFrame": "Generalist economist when no field/school matches",
      "decisionEmphasis": ["frame positive vs normative", "list mechanisms and assumptions", "route to a field specialist"]
    },
    "decisionContract": [
      "Frame the question and separate positive analysis from normative value choices.",
      "State assumptions and the mechanisms (incentives, prices, expectations) at work.",
      "Give scenarios with explicit uncertainty ranges; cite data sources.",
      "Map distributional impacts: who gains, who loses, and by how much.",
      "Offer strict / moderate / permissive policy options with tradeoffs.",
      "Flag value judgments requiring human and democratic accountability. End with Decision and 中文摘要."
    ]
  }
