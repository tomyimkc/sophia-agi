{"id": "expand_sq_clean", "domain": "math", "errorType": "none", "expectVerified": true, "gold": "x**2 + 2*x + 1", "steps": [{"expr": "(x+1)**2", "rule": "start"}, {"expr": "x*(x+1) + 1*(x+1)", "rule": "distribute (x+1)"}, {"expr": "x**2 + x + x + 1", "rule": "distribute again"}, {"expr": "x**2 + 2*x + 1", "rule": "collect like terms"}]}
{"id": "expand_sq_sign", "domain": "math", "errorType": "sign", "expectVerified": false, "gold": "x**2 + 2*x + 1", "steps": [{"expr": "(x+1)**2", "rule": "start"}, {"expr": "x*(x+1) + 1*(x+1)", "rule": "distribute (x+1)"}, {"expr": "x**2 + x + x + 1", "rule": "distribute again"}, {"expr": "x**2 - 2*x + 1", "rule": "WRONG sign on linear term"}]}
{"id": "expand_sq_dropfactor", "domain": "math", "errorType": "dropped_factor", "expectVerified": false, "gold": "x**2 + 2*x + 1", "steps": [{"expr": "(x+1)**2", "rule": "start"}, {"expr": "x*(x+1) + 1*(x+1)", "rule": "distribute (x+1)"}, {"expr": "x**2 + x + 1", "rule": "DROPPED a middle x"}]}
{"id": "diff_squares_clean", "domain": "math", "errorType": "none", "expectVerified": true, "gold": "x**2 - 4", "steps": [{"expr": "(x+2)*(x-2)", "rule": "start"}, {"expr": "x**2 - 2*x + 2*x - 4", "rule": "FOIL"}, {"expr": "x**2 - 4", "rule": "cancel cross terms"}]}
{"id": "diff_squares_sign", "domain": "math", "errorType": "sign", "expectVerified": false, "gold": "x**2 - 4", "steps": [{"expr": "(x+2)*(x-2)", "rule": "start"}, {"expr": "x**2 - 2*x + 2*x - 4", "rule": "FOIL"}, {"expr": "x**2 + 4", "rule": "WRONG sign on constant"}]}
{"id": "combine_linear_clean", "domain": "math", "errorType": "none", "expectVerified": true, "gold": "3*x - 2", "steps": [{"expr": "(2*x+3) + (x-5)", "rule": "start"}, {"expr": "2*x + x + 3 - 5", "rule": "regroup"}, {"expr": "3*x - 2", "rule": "combine"}]}
{"id": "combine_linear_arith", "domain": "math", "errorType": "arithmetic", "expectVerified": false, "gold": "3*x - 2", "steps": [{"expr": "(2*x+3) + (x-5)", "rule": "start"}, {"expr": "2*x + x + 3 - 5", "rule": "regroup"}, {"expr": "3*x + 2", "rule": "WRONG 3-5"}]}
{"id": "factor_cancel_clean", "domain": "math", "errorType": "none", "expectVerified": true, "gold": "x + 1", "steps": [{"expr": "(x**2 - 1)/(x - 1)", "rule": "start"}, {"expr": "((x-1)*(x+1))/(x-1)", "rule": "factor numerator"}, {"expr": "x + 1", "rule": "cancel (x-1)"}]}
{"id": "factor_cancel_sign", "domain": "math", "errorType": "sign", "expectVerified": false, "gold": "x + 1", "steps": [{"expr": "(x**2 - 1)/(x - 1)", "rule": "start"}, {"expr": "((x-1)*(x+1))/(x-1)", "rule": "factor numerator"}, {"expr": "x - 1", "rule": "WRONG cancelled factor"}]}
{"id": "cube_binomial_clean", "domain": "math", "errorType": "none", "expectVerified": true, "gold": "x**3 + 3*x**2 + 3*x + 1", "steps": [{"expr": "(x+1)**3", "rule": "start"}, {"expr": "(x+1)*(x**2 + 2*x + 1)", "rule": "(x+1)*(x+1)^2"}, {"expr": "x**3 + 3*x**2 + 3*x + 1", "rule": "expand"}]}
{"id": "cube_binomial_dropfactor", "domain": "math", "errorType": "dropped_factor", "expectVerified": false, "gold": "x**3 + 3*x**2 + 3*x + 1", "steps": [{"expr": "(x+1)**3", "rule": "start"}, {"expr": "(x+1)*(x**2 + x + 1)", "rule": "WRONG (x+1)^2 expansion"}, {"expr": "x**3 + 2*x**2 + 2*x + 1", "rule": "expand"}]}
{"id": "distribute_clean", "domain": "math", "errorType": "none", "expectVerified": true, "gold": "3*x + 12", "steps": [{"expr": "3*(x+4)", "rule": "start"}, {"expr": "3*x + 12", "rule": "distribute"}]}
{"id": "distribute_dropfactor", "domain": "math", "errorType": "dropped_factor", "expectVerified": false, "gold": "3*x + 12", "steps": [{"expr": "3*(x+4)", "rule": "start"}, {"expr": "3*x + 4", "rule": "DID NOT multiply the 4"}]}
{"id": "trig_pyth_clean", "domain": "math", "errorType": "none", "expectVerified": true, "gold": "1", "steps": [{"expr": "sin(x)**2 + cos(x)**2", "rule": "start"}, {"expr": "1", "rule": "Pythagorean identity"}]}
{"id": "fraction_add_clean", "domain": "math", "errorType": "none", "expectVerified": true, "gold": "5/6", "steps": [{"expr": "1/2 + 1/3", "rule": "start"}, {"expr": "3/6 + 2/6", "rule": "common denominator"}, {"expr": "5/6", "rule": "add"}]}
{"id": "fraction_add_arith", "domain": "math", "errorType": "arithmetic", "expectVerified": false, "gold": "5/6", "steps": [{"expr": "1/2 + 1/3", "rule": "start"}, {"expr": "3/6 + 2/6", "rule": "common denominator"}, {"expr": "4/6", "rule": "WRONG 3+2"}]}
{"id": "ab_identity_clean", "domain": "math", "errorType": "none", "expectVerified": true, "gold": "4*a*b", "steps": [{"expr": "(a+b)**2 - (a-b)**2", "rule": "start"}, {"expr": "(a**2 + 2*a*b + b**2) - (a**2 - 2*a*b + b**2)", "rule": "expand both"}, {"expr": "4*a*b", "rule": "cancel and combine"}]}
{"id": "ab_identity_sign", "domain": "math", "errorType": "sign", "expectVerified": false, "gold": "4*a*b", "steps": [{"expr": "(a+b)**2 - (a-b)**2", "rule": "start"}, {"expr": "(a**2 + 2*a*b + b**2) - (a**2 - 2*a*b + b**2)", "rule": "expand both"}, {"expr": "2*a*b", "rule": "WRONG combine"}]}
