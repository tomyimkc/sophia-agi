# --- Option A: Claude via LLMHub proxy (recommended) ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.llmhub.com.cn
ANTHROPIC_MODEL=claude-sonnet-4-6
# CLAUDE_API_KEY=              # alias for ANTHROPIC_API_KEY
# CLAUDE_BASE_URL=             # alias for ANTHROPIC_BASE_URL

# --- Optional: other providers ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
XAI_API_KEY=
XAI_MODEL=x-ai/grok-3-beta
MONICA_API_KEY=

# --- Unified model adapter (agent/model.py): GLM-5.2 / frontier / local ---
# Presets: anthropic | openai | glm | deepseek | ollama | vllm | sglang | llamacpp | grok | openclaw | mock
# SOPHIA_MODEL_PROVIDER selects the primary (auto-detects if unset; mock if no creds).
SOPHIA_MODEL_PROVIDER=            # e.g. glm  (or glm:glm-5.2 to pin the model)
SOPHIA_MODEL=                     # model name override (e.g. glm-5.2, llama3.1, deepseek-chat)
SOPHIA_MODEL_BASE_URL=           # override base_url for any OpenAI-compatible server (vLLM/SGLang/Ollama/llama.cpp)
SOPHIA_MODEL_FALLBACKS=          # comma list, e.g. "glm,deepseek,mock" (tried in order on failure)
SOPHIA_REASONING_EFFORT=         # low | medium | high (passed to providers that support it)
SOPHIA_MAX_TOKENS=2400
SOPHIA_TEMPERATURE=0.2
SOPHIA_MODEL_RETRIES=2
SOPHIA_TIMEOUT_SEC=120
# SOPHIA_MODEL_PRICES={"glm-5":[0.8,3.0]}   # USD per 1M tokens (in,out) overrides for cost tracking
# GLM-5.2 (Zhipu): set SOPHIA_MODEL_PROVIDER=glm, SOPHIA_MODEL=glm-5.2, ZHIPUAI_API_KEY=...
ZHIPUAI_API_KEY=
DEEPSEEK_API_KEY=
# Local OpenAI-compatible servers need only a base_url (+ dummy key handled by preset):
#   Ollama:  SOPHIA_MODEL_PROVIDER=ollama  SOPHIA_MODEL=llama3.1
#   vLLM:    SOPHIA_MODEL_PROVIDER=vllm    SOPHIA_MODEL_BASE_URL=http://localhost:8000/v1
# OpenClaw gateway (Node CLI, NOT a Python lib — shelled out): SOPHIA_MODEL_PROVIDER=openclaw
#   route a provider/model via the spec, e.g. openclaw:anthropic/claude-sonnet-4-6 (preset default: xai/grok-4.3).
#   Needs a running, authed openclaw daemon; pair with SOPHIA_MODEL_FALLBACKS=...,mock to stay offline-testable.
SOPHIA_OPENCLAW_BIN=              # override the openclaw binary name/path (default "openclaw" on PATH)

# --- Hugging Face dataset upload ---
HF_TOKEN=hf_your_token_here
HF_REPO_ID=tomyimkc/sophia-agi-corpus

# Optional: create community issues via tools/create_github_issues.py
GITHUB_TOKEN=

# --- Online RAG (curated index + Gemini or Claude) ---
# Build index: python tools/build_rag_index.py
# CLI: python tools/sophia_rag.py "Your question?"
GOOGLE_API_KEY=
# GEMINI_API_KEY=              # alias for GOOGLE_API_KEY
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004
SOPHIA_RAG_BACKEND=auto        # auto | gemini | vertex | claude | keyword
SOPHIA_RAG_INDEX_DIR=rag/index

# Vertex AI (production Cloud Run) — set GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_GENAI_USE_VERTEXAI=false
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Web evidence search (opt-in; do not use on hidden packs without approval) ---
# CLI local-only: python tools/sophia_agent.py web_evidence "query"
# CLI online:     python tools/sophia_agent.py web_evidence "query" --web-evidence --web-provider auto
SOPHIA_WEB_SEARCH_PROVIDER=off # off | auto | brave | tavily | serpapi
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=

# RunPod — used by the runpod-mcp skill / .mcp.json `runpod` server (manage pods,
# check status) and by the speedup-runpod workflow. Put the real value in .env
# (gitignored), never here. Get/rotate a key at https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=
